# nuxt-auth-utils — sealed cookie key (generate: openssl rand -base64 32)
NUXT_SESSION_PASSWORD=

# GitHub OAuth App (Settings → Developer settings → OAuth Apps)
# Callback URL: https://adiaryasuta.dev/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# Admin access — the GitHub username that is allowed to log in
NUXT_ADMIN_GITHUB_LOGIN=adiiaryasutaa

# Secret URL slug — admin lives at /{NUXT_ADMIN_SLUG}
# Use something random, e.g.: openssl rand -hex 6
NUXT_ADMIN_SLUG=

# GitHub PAT — fine-grained token with Contents: Read & Write on this repo
NUXT_GITHUB_PAT=

# GitHub repo info
NUXT_GITHUB_REPO_OWNER=adiiaryasutaa
NUXT_GITHUB_REPO_NAME=adiiaryasutaa-web
NUXT_GITHUB_BRANCH=main
